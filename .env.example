# ─────────────────────────────────────────────────────────────────────────────
# Plantilla de variables de entorno de Spotr
#
# Copia este archivo como `.env` en la carpeta de cada servicio de backend
# (api-gateway/, places_rest/, maps_graphql/) o en la raíz si ejecutas desde
# ahí, y rellena los valores reales. NUNCA subas tu `.env` al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# Cadena de conexión a MongoDB Atlas.
# Requerida por: api-gateway, places_rest, maps_graphql
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/spotr

# Secreto usado para firmar y verificar los JSON Web Tokens.
# Requerida por: api-gateway
JWT_SECRET=cambia-esto-por-un-string-largo-y-aleatorio

# Credenciales de Cloudinary (almacenamiento y CDN de imágenes).
# Requeridas por: api-gateway
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# Puerto del servicio (opcional — cada servicio tiene un valor por defecto:
# api-gateway 5500, places_rest 4000, maps_graphql 4001).
# PORT=5500
